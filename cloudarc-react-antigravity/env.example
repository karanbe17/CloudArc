# CloudArc POS — Environment Variables
# =====================================================
# ⚡ STEP 1: Once your Flask API is deployed, paste the URL below
# ⚡ STEP 2: Run `npm run dev` — everything connects automatically
# =====================================================

VITE_API_URL=http://localhost:5001

# When deployed to Vercel/Render, update to:
# VITE_API_URL=https://cloudarc-api.onrender.com
